{
  "name": "@megasaver/mcp-bridge",
  "version": "1.2.1",
  "license": "MIT",
  "private": true,
  "description": "Mega Saver MCP server bridge — stdio transport, four context-gate tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@megasaver/content-store": "workspace:*",
    "@megasaver/context-pruner": "workspace:*",
    "@megasaver/core": "workspace:*",
    "@megasaver/embeddings": "workspace:*",
    "@megasaver/daemon": "workspace:*",
    "@megasaver/evidence-ledger": "workspace:*",
    "@megasaver/indexer": "workspace:*",
    "@megasaver/output-filter": "workspace:*",
    "@megasaver/policy": "workspace:*",
    "@megasaver/retrieval": "workspace:*",
    "@megasaver/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17"
  }
}
