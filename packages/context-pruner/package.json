{
  "name": "@megasaver/context-pruner",
  "version": "0.1.0",
  "private": true,
  "description": "Task-aware context pruning (LAMR) for Mega Saver — multi-factor block scoring into a context pack.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.test.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@megasaver/embeddings": "workspace:*",
    "@megasaver/indexer": "workspace:*",
    "@megasaver/retrieval": "workspace:*",
    "@megasaver/shared": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17"
  }
}
