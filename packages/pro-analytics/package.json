{
  "name": "@megasaver/pro-analytics",
  "version": "0.1.1",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "description": "Mega Saver Pro — proprietary historical savings analytics and export. Use requires a valid Mega Saver Pro license.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
