# Dependencies
node_modules/
.pnpm-store/
.pnpm-debug.log*

# Build artifacts
dist/
dist-bundle/
dist-bridge/
build/
.turbo/
.worktrees/
*.tsbuildinfo

# Transient pack backup: apps/cli prepack strips the published manifest and
# postpack restores it from this file. Never committed; gone after a clean pack.
package.json.bak

# Test artifacts
coverage/
.vitest-cache/
# Vitest typecheck writes these transient configs at package roots and
# normally deletes them on clean exit; an interrupted/concurrent run can
# leave one behind. Ignore so it never trips biome lint or gets committed.
**/tsconfig.vitest-temp.json
**/tsconfig.tmp.json

# Local env
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Mega Saver runtime store (project-local state) — never committed
**/.megasaver/*
!**/.megasaver/policy.json

# Wiki raw sources — local-only.
# Per the wiki schema (wiki/CLAUDE.md), raw/ contents are read by the
# agent but never modified. Some raw sources contain pre-publication
# product notes and are excluded from public history. The agent works
# from the indexed summary in wiki/sources/ instead.
wiki/raw/*.txt
wiki/raw/*.md
wiki/raw/*.pdf
!wiki/raw/.gitkeep

# OMC runtime
.omc/

# AI agent / assistant tooling — personal, never committed.
# NOTE: the product's own dogfood files (CLAUDE.md, AGENTS.md, CONVENTIONS.md,
# .cursor/rules/*.mdc) ARE tracked on purpose and must stay out of this list.
.claude/
.claire/
.cursorrules
.mcp.json
GEMINI.md
.github/copilot-instructions.md
.aider*
.continue/
.windsurf/
.codeium/

# Personal local dev helpers (machine-specific launchers, scratch)
scripts/launch-megasaver.sh

# Pro license signing key — the vendor's OFFLINE Ed25519 private key. Generated
# by scripts/license/gen-keypair.mjs, kept off the repo forever. Only the public
# key is committed (baked into packages/entitlement/src/public-key.ts).
scripts/license/.private-key.pem

# Local WIP — not part of the published repo
.github/workflows/changeset-check.yml
.github/workflows/coverage.yml
packages/agent-office/test/supervisor-permission-edge.test.ts
packages/context-pruner/test/score-edge.test.ts
.superpowers/
