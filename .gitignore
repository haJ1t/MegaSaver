# Dependencies
node_modules/
.pnpm-store/
.pnpm-debug.log*

# Build artifacts
dist/
dist-bundle/
build/
.turbo/
.worktrees/
*.tsbuildinfo

# Transient pack backup: apps/cli prepack strips the published manifest and
# postpack restores it from this file. Never committed; gone after a clean pack.
package.json.bak

# Test artifacts
coverage/
.vitest-cache/
# Vitest typecheck writes these transient configs at package roots and
# normally deletes them on clean exit; an interrupted/concurrent run can
# leave one behind. Ignore so it never trips biome lint or gets committed.
**/tsconfig.vitest-temp.json
**/tsconfig.tmp.json

# Local env
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Mega Saver runtime (project-local state)
.megasaver/state/
.megasaver/sessions/
.megasaver/cache/
.megasaver/hooks/

# Wiki raw sources — local-only.
# Per the wiki schema (wiki/CLAUDE.md), raw/ contents are read by the
# agent but never modified. Some raw sources contain pre-publication
# product notes and are excluded from public history. The agent works
# from the indexed summary in wiki/sources/ instead.
wiki/raw/*.txt
wiki/raw/*.md
wiki/raw/*.pdf
!wiki/raw/.gitkeep

# OMC runtime
.omc/state/
.omc/sessions/
.omc/logs/
