# Dependencies
node_modules/
.pnpm-store/
.pnpm-debug.log*

# Build artifacts
dist/
build/
.turbo/
.worktrees/
*.tsbuildinfo

# Test artifacts
coverage/
.vitest-cache/

# Local env
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Mega Saver runtime (project-local state)
.megasaver/state/
.megasaver/sessions/
.megasaver/cache/

# Wiki raw sources — local-only.
# Per the wiki schema (wiki/CLAUDE.md), raw/ contents are read by the
# agent but never modified. Some raw sources contain pre-publication
# product notes and are excluded from public history. The agent works
# from the indexed summary in wiki/sources/ instead.
wiki/raw/*.txt
wiki/raw/*.md
wiki/raw/*.pdf
!wiki/raw/.gitkeep

# OMC runtime
.omc/state/
.omc/sessions/
.omc/logs/
