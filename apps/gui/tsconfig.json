{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "incremental": false,
    "composite": false,
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "bridge/**/*"],
  "exclude": ["test", "dist", "node_modules", ".turbo"]
}
