{
  "name": "@megasaver/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Mega Saver CLI - the `mega` command.",
  "type": "module",
  "bin": {
    "mega": "./dist/cli.js"
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.test.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
