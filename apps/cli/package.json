{
  "name": "@megasaver/cli",
  "version": "1.7.0",
  "license": "SEE LICENSE IN NOTICE",
  "description": "Mega Saver CLI - the `mega` command.",
  "type": "module",
  "bin": {
    "mega": "./dist-bundle/mega.mjs"
  },
  "files": ["dist-bundle", "LICENSE", "PRO-LICENSE", "NOTICE"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.3.3"
  },
  "scripts": {
    "build": "tsup",
    "bundle": "tsup --config tsup.bundle.config.ts",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.test.json --noEmit",
    "clean": "rm -rf dist dist-bundle .turbo",
    "prepack": "pnpm turbo build --filter=@megasaver/cli... && pnpm run bundle && node scripts/copy-gui-dist.mjs && node scripts/strip-publish-manifest.mjs prepack",
    "postpack": "node scripts/strip-publish-manifest.mjs postpack"
  },
  "devDependencies": {
    "@megasaver/agent-office": "workspace:*",
    "@megasaver/connector-claude-code": "workspace:*",
    "@megasaver/connector-generic-cli": "workspace:*",
    "@megasaver/connectors-shared": "workspace:*",
    "@megasaver/content-store": "workspace:*",
    "@megasaver/context-gate": "workspace:*",
    "@megasaver/context-pruner": "workspace:*",
    "@megasaver/core": "workspace:*",
    "@megasaver/daemon": "workspace:*",
    "@megasaver/entitlement": "workspace:*",
    "@megasaver/gui": "workspace:*",
    "@megasaver/indexer": "workspace:*",
    "@megasaver/llm-proxy": "workspace:*",
    "@megasaver/mcp-bridge": "workspace:*",
    "@megasaver/memory-graph": "workspace:*",
    "@megasaver/output-filter": "workspace:*",
    "@megasaver/policy": "workspace:*",
    "@megasaver/pro-analytics": "workspace:*",
    "@megasaver/proxy-control": "workspace:*",
    "@megasaver/shared": "workspace:*",
    "@megasaver/skill-packs": "workspace:*",
    "@types/node": "^22.0.0",
    "citty": "^0.1.6",
    "zod": "^3.24.1"
  }
}
